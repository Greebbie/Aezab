# Pre-built frontend (console build output copied in at Docker build time —
# not source). widget.js is hand-written source that must live at this path
# to be served by server/main.py's static mount, so it is excluded from the
# blanket ignore below. (Directory-level "static/" would also hide negated
# files inside it, so this ignores direct entries instead.)
static/*
!static/widget.js

