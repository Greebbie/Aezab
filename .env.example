# HlAB Agent Builder Configuration
# Copy to .env and fill in your values:  cp .env.example .env

# ── App ──────────────────────────────────────────
HLAB_DEBUG=false

# ── Database ─────────────────────────────────────
# SQLite (default, for development)
HLAB_DATABASE_URL=sqlite+aiosqlite:///./data/hlab.db
# PostgreSQL (production)
# HLAB_DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/hlab

# ── LLM ──────────────────────────────────────────
# Provider: openai_compatible | dashscope | zhipu | local
HLAB_LLM_PROVIDER=openai_compatible
# Docker Compose Ollama service: http://ollama:11434/v1
# Local source-code run with host Ollama: http://localhost:11434/v1
HLAB_LLM_BASE_URL=http://ollama:11434/v1
HLAB_LLM_API_KEY=your-api-key-here
HLAB_LLM_MODEL=qwen-flash
HLAB_LLM_TIMEOUT=60

# DashScope example:
# HLAB_LLM_PROVIDER=dashscope
# HLAB_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# HLAB_LLM_API_KEY=sk-xxxxx
# HLAB_LLM_MODEL=qwen-flash

# ── Embedding ────────────────────────────────────
HLAB_EMBEDDING_PROVIDER=local
HLAB_EMBEDDING_MODEL=BAAI/bge-m3
HLAB_EMBEDDING_DIM=1024
# HuggingFace mirror used by sentence-transformers model downloads.
# Use https://hf-mirror.com for China-friendly local model downloads.
HLAB_HF_ENDPOINT=https://hf-mirror.com

# Speech to Text / ASR
# Provider: dashscope_qwen | funasr_http | openai_compatible | disabled
HLAB_ASR_PROVIDER=dashscope_qwen
HLAB_ASR_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
HLAB_ASR_API_KEY=
HLAB_ASR_MODEL=qwen3-asr-flash
HLAB_ASR_TIMEOUT=60
HLAB_ASR_MAX_FILE_MB=10
HLAB_ASR_CONFIG_PATH=./data/asr_config.json
# Used when HLAB_ASR_PROVIDER=funasr_http and base URL is only a host.
HLAB_ASR_FUNASR_PATH=/transcribe

# ── Vector Store ─────────────────────────────────
HLAB_VECTOR_STORE=faiss
HLAB_FAISS_INDEX_DIR=./data/faiss

# ── CORS ─────────────────────────────────────────
# Restrict in production
HLAB_CORS_ORIGINS=*

# ── Auth ─────────────────────────────────────────
HLAB_DISABLE_AUTH=true
HLAB_SECRET_KEY=change-me-in-production

# ── Audit ────────────────────────────────────────
HLAB_AUDIT_ENABLED=true
