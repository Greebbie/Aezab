# Aezab configuration
# Copy this file to .env and adjust values for your environment.
#
# AEZAB_ is the primary prefix. Legacy HLAB_ variables are still accepted
# by the backend for existing deployments.

# App
AEZAB_DEBUG=false

# Database
# SQLite is the default for local development.
AEZAB_DATABASE_URL=sqlite+aiosqlite:///./data/aezab.db

# PostgreSQL example for production.
# AEZAB_DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/aezab

# LLM
# Provider: openai_compatible | dashscope | zhipu | local
AEZAB_LLM_PROVIDER=openai_compatible

# Recommended: leave AEZAB_LLM_BASE_URL / AEZAB_LLM_MODEL unset. Open the
# console on first run and follow the setup wizard to connect a cloud
# model instead — it writes a config to the database, which always takes
# priority over these environment variable defaults. An unset base URL
# means "not configured yet"; the console will guide you through it.
# AEZAB_LLM_BASE_URL=
AEZAB_LLM_API_KEY=your-api-key-here
# AEZAB_LLM_MODEL=
AEZAB_LLM_TIMEOUT=60

# DashScope example
# AEZAB_LLM_PROVIDER=dashscope
# AEZAB_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# AEZAB_LLM_API_KEY=sk-xxxxx
# AEZAB_LLM_MODEL=qwen-flash

# Optional: local LLM via Ollama (fully offline, no cloud API key needed).
# Not started by default — bring it up explicitly with:
#   docker compose --profile local-llm up -d
# which starts the ollama service and pulls qwen2.5:1.5b (~1GB) once.
# Then point the LLM settings at it:
# AEZAB_LLM_BASE_URL=http://ollama:11434/v1   # Docker Compose
# AEZAB_LLM_BASE_URL=http://localhost:11434/v1  # local source-code run with host Ollama
# AEZAB_LLM_MODEL=qwen2.5:1.5b

# Embeddings
AEZAB_EMBEDDING_PROVIDER=local
AEZAB_EMBEDDING_MODEL=BAAI/bge-m3
AEZAB_EMBEDDING_DIM=1024

# China-friendly HuggingFace mirror for local model downloads.
AEZAB_HF_ENDPOINT=https://hf-mirror.com

# Knowledge upload
# Supported: .txt, .md, .pdf, .docx, .csv, .xlsx
AEZAB_KNOWLEDGE_MAX_UPLOAD_MB=50

# Speech to Text / ASR
# Provider: dashscope_qwen | funasr_http | openai_compatible | disabled
AEZAB_ASR_PROVIDER=dashscope_qwen
AEZAB_ASR_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
AEZAB_ASR_API_KEY=
AEZAB_ASR_MODEL=qwen3-asr-flash
AEZAB_ASR_TIMEOUT=60
AEZAB_ASR_MAX_FILE_MB=10
AEZAB_ASR_CONFIG_PATH=./data/asr_config.json

# Used when AEZAB_ASR_PROVIDER=funasr_http and the base URL is only a host.
AEZAB_ASR_FUNASR_PATH=/transcribe

# Vector store
AEZAB_VECTOR_STORE=faiss
AEZAB_FAISS_INDEX_DIR=./data/vectors

# CORS
# Restrict this in production, for example:
# AEZAB_CORS_ORIGINS=https://app.example.com,https://admin.example.com
AEZAB_CORS_ORIGINS=*

# Auth
# The first time you open the console with auth enabled, you'll be guided
# through creating an admin account — no manual setup needed. Only set this
# to true for local, single-machine development where login is unnecessary.
AEZAB_DISABLE_AUTH=false

# Leave unset to auto-generate a random secret key on first boot, persisted
# to ./data/secret_key. You normally don't need to set this yourself.
# AEZAB_SECRET_KEY=

# The outward-facing API key (for headless /invoke callers) is created from
# the console's Integrations page, not configured here.
# AEZAB_API_KEY=

# Audit
AEZAB_AUDIT_ENABLED=true

# Audit trace retention: how many days of audit_traces rows to keep before
# a background job purges them (runs every 24h). 90 by default. Set to 0
# to keep audit records forever (disables the purge). This does NOT affect
# conversation history (messages/sessions) — only the audit log.
AEZAB_AUDIT_RETENTION_DAYS=90

# Backups
# Zero-config local backup of the database, vector index, and local config
# files to ./data/backups/ — no operator action required. Runs automatically
# every AEZAB_BACKUP_INTERVAL_HOURS hours, keeping only the newest
# AEZAB_BACKUP_KEEP copies. Set AEZAB_BACKUP_INTERVAL_HOURS=0 to disable.
# Manage backups (create/list/download/delete) from the console's Settings
# page, or via the admin-only /api/v1/backups API.
AEZAB_BACKUP_KEEP=7
AEZAB_BACKUP_INTERVAL_HOURS=24
